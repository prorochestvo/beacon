# sqlite_dump.sh overrides — copy to /opt/beacon/backups/.env on the host and edit.
# sqlite_dump.sh sources this file (if present, next to the script) before its own
# defaults, so anything set here wins.

# Google Drive destination (rclone remote name + path). Default shown.
#GDRIVE_REMOTE=gdrive:backups/beacon

# Retention windows in days. Local host is short (scarce disk); Drive is the archive.
#LOCAL_RETENTION_DAYS=7
#REMOTE_RETENTION_DAYS=14

# Telegram reporting (success summary + failure alert). By default the script reads
# BEACON_TELEGRAMBOT_DSN from the service env file (MAIN_ENV below) and needs nothing
# here. Set these two only to report through a dedicated bot/chat instead; both must be
# set to take effect.
#ALERT_TELEGRAM_TOKEN=123456789:AA...
#ALERT_TELEGRAM_CHAT_ID=123456789

# Service env file reporting falls back to for BEACON_TELEGRAMBOT_DSN. Default shown.
#MAIN_ENV=/opt/beacon/.env

# Set to 0 to silence the per-run "#BEACON backup OK" summary (failures still alert).
#NOTIFY_ON_SUCCESS=1
